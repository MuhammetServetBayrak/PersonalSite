@model EntityLayer.Concrete.BlogPost
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Title;
}

<style>
    .post-header {
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 0.5px solid var(--border);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .post-category-badge {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 99px;
        background: rgba(56,189,248,0.12);
        color: var(--accent);
        font-family: monospace;
        text-decoration: none;
    }

    .post-date {
        font-size: 12px;
        color: var(--text-muted);
    }

    .post-title {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.3;
    }

    .post-content {
        font-size: 15px;
        line-height: 1.8;
        color: var(--text-main);
    }

        .post-content img {
            max-width: 100%;
            border-radius: 8px;
            margin: 16px 0;
        }

        .post-content h1, .post-content h2, .post-content h3 {
            color: var(--accent);
            margin: 24px 0 12px;
        }

        .post-content p {
            margin-bottom: 16px;
        }

        .post-content code {
            background: var(--bg-card2);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: monospace;
            font-size: 13px;
            color: var(--accent);
        }

        .post-content pre {
            background: var(--bg-card2);
            padding: 16px;
            border-radius: 8px;
            overflow-x: auto;
            margin: 16px 0;
            border: 0.5px solid var(--border);
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 24px;
        transition: color 0.2s;
    }

        .back-btn:hover {
            color: var(--accent);
        }
</style>

<a href="/Blog" class="back-btn">
    <i class="ti ti-arrow-left"></i> Yazılara Dön
</a>

<div class="post-header">
    <div class="post-meta">
        <a href="/Blog?categoryId=@Model.BlogCategoryId" class="post-category-badge">
            @Model.BlogCategory?.Name
        </a>
        <span class="post-date">
            <i class="ti ti-calendar" style="font-size: 12px;"></i>
            @Model.CreatedDate.ToString("dd MMMM yyyy")
        </span>
    </div>
    <div class="post-title">@Model.Title</div>
</div>

<div class="post-content">
    @Html.Raw(Model.Content)
</div>