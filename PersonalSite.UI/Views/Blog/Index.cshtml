@model List<EntityLayer.Concrete.BlogPost>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Blog";
}


<div class="blog-wrap">
    <div class="blog-sidebar">
        <div class="sidebar-title">Kategoriler</div>
        <div class="category-list">
            <a href="/Blog" class="category-item @(ViewBag.SelectedCategory == null ? "active" : "")">
                <i class="ti ti-list"></i> Tümü
            </a>
            @foreach (var cat in ViewBag.Categories)
            {
                <a href="/Blog?categoryId=@cat.Id" class="category-item @(ViewBag.SelectedCategory == cat.Id ? "active" : "")">
                    <i class="ti ti-tag"></i> @cat.Name
                </a>
            }
        </div>
    </div>

    <div class="post-list">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="ti ti-news" style="font-size: 32px; display: block; margin-bottom: 12px;"></i>
                Henüz yazı yok.
            </div>
        }
        else
        {
            @foreach (var post in Model)
            {
                <a href="/Blog/Detail/@post.Id" class="post-card">
                    <div class="post-category">@post.BlogCategory?.Name</div>
                    <div class="post-title">@post.Title</div>
                    <div class="post-date">
                        <i class="ti ti-calendar" style="font-size: 12px;"></i>
                        @post.CreatedDate.ToString("dd MMMM yyyy")
                    </div>
                </a>
            }
        }
    </div>
</div>