<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muhammet Servet</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        [data-bs-theme="dark"] {
            --bg-main: #0d1117;
            --bg-card: #161b22;
            --bg-card2: #21262d;
            --text-main: #e6edf3;
            --text-muted: rgba(255,255,255,0.5);
            --border: rgba(255,255,255,0.08);
            --accent: #38bdf8;
            --accent-text: #0a0e1a;
        }

        [data-bs-theme="light"] {
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --bg-card2: #f1f5f9;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --accent: #0ea5e9;
            --accent-text: #ffffff;
        }

        body {
            background: var(--bg-main);
            color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            transition: background 0.3s, color 0.3s;
        }

        .navbar {
            background: var(--bg-card);
            border-bottom: 0.5px solid var(--border);
            padding: 0 40px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-logo {
            font-size: 16px;
            font-weight: 600;
            color: var(--accent);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .navbar-nav {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .navbar-nav a {
            padding: 6px 14px;
            font-size: 13px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .navbar-nav a:hover {
            color: var(--text-main);
            background: var(--bg-card2);
        }

        .navbar-nav .dropdown {
            position: relative;
        }

        .navbar-nav .dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: var(--bg-card);
            border: 0.5px solid var(--border);
            border-radius: 8px;
            padding: 6px;
            min-width: 180px;
            margin-top: 4px;
        }

        .navbar-nav .dropdown:hover .dropdown-menu {
            display: block;
        }

        .navbar-nav .dropdown-menu a {
            display: block;
            padding: 7px 12px;
            border-radius: 6px;
        }

        .navbar-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-theme {
            background: none;
            border: 0.5px solid var(--border);
            color: var(--text-muted);
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            transition: all 0.2s;
        }

        .btn-theme:hover {
            color: var(--text-main);
            border-color: var(--accent);
        }

        .page-content {
            max-width: 1100px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        footer {
            border-top: 0.5px solid var(--border);
            padding: 24px 40px;
            text-align: center;
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 60px;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="navbar-logo">
            <i class="ti ti-terminal-2"></i> MS Bayrak
        </a>
        <div class="navbar-nav">
            <a href="/About">Hakkımda</a>
            <div class="dropdown">
                <a href="/Blog">Çözümler <i class="ti ti-chevron-down" style="font-size:12px;"></i></a>
                <div class="dropdown-menu" id="categoryMenu">
                    <a href="/Blog">Tümü</a>
                </div>
            </div>
            <a href="/Projects">Projeler</a>
        </div>
        <div class="navbar-actions">
            <button class="btn-theme" onclick="toggleTheme()">
                <i class="ti ti-sun" id="themeIcon"></i>
            </button>
        </div>
    </nav>

    <div class="page-content">
        @RenderBody()
    </div>

    <footer>
        <p>© 2026 Muhammet Servet Bayrak · Sistem Yöneticisi & Teknik Destek Uzmanı</p>
    </footer>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-bs-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            localStorage.setItem('theme', next);
            document.getElementById('themeIcon').className = next === 'dark' ? 'ti ti-sun' : 'ti ti-moon';
        }
        const saved = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-bs-theme', saved);
        document.getElementById('themeIcon').className = saved === 'dark' ? 'ti ti-sun' : 'ti ti-moon';
    </script>
</body>
</html>