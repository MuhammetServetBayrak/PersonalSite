<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muhammet Servet</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar">
        <a href="/" class="navbar-logo">
            <i class="ti ti-terminal-2"></i> MS Bayrak
        </a>
        <div class="navbar-nav">
            <a href="/About">Hakkımda</a>
            <a href="/Blog">Çözümler</a>
            <a href="/Projects">Projeler</a>
        </div>        <div class="navbar-actions">
            <button class="btn-theme" onclick="toggleTheme()">
                <i class="ti ti-sun" id="themeIcon"></i>
            </button>
        </div>
    </nav>

    <div class="page-content">
        @RenderBody()
    </div>

    <footer>
        <p>© 2026 Muhammet Servet Bayrak · Sistem Yöneticisi & Teknik Destek Uzmanı</p>
    </footer>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-bs-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            localStorage.setItem('theme', next);
            document.getElementById('themeIcon').className = next === 'dark' ? 'ti ti-sun' : 'ti ti-moon';
        }
        const saved = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-bs-theme', saved);
        document.getElementById('themeIcon').className = saved === 'dark' ? 'ti ti-sun' : 'ti ti-moon';
    </script>
</body>
</html>