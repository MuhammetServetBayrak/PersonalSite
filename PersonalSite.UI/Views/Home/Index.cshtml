@{
    ViewData["Title"] = "Anasayfa";
}

<div class="hero-compact">
    <div class="hero-eyebrow">Sistem Yöneticisi · Netinternet</div>
    <div class="hero-name">Muhammet Servet Bayrak</div>
    <div class="hero-desc">
        Linux, sanallaştırma, network ve sunucu yönetimi alanlarında edindiğim
        deneyimleri burada paylaşıyorum.
    </div>
    <div class="hero-btns">
        <a href="/About" class="btn-primary">Hakkımda</a>
        <a href="/Blog" class="btn-secondary">Yazılarım</a>
    </div>
    <div class="tech-badges">
        <span class="tech-badge">ESXi</span>
        <span class="tech-badge">vCenter</span>
        <span class="tech-badge">Veeam Backup</span>
        <span class="tech-badge">Linux</span>
        <span class="tech-badge">Windows Server</span>
        <span class="tech-badge">Network</span>
        <span class="tech-badge">cPanel</span>
        <span class="tech-badge">Plesk</span>
        <span class="tech-badge">SSH</span>
    </div>
</div>

@if (ViewBag.RecentPosts != null && ViewBag.RecentPosts.Count > 0)
{
    <div class="home-section">
        <div class="home-section-header">
            <div class="home-section-title"><i class="ti ti-news"></i> Son Yazılar</div>
            <a href="/Blog" class="home-section-more">Tümünü Gör <i class="ti ti-arrow-right"></i></a>
        </div>
        <div class="home-posts-grid">
            @foreach (var post in ViewBag.RecentPosts)
            {
                <a href="/Blog/Detail/@post.Id" class="home-post-card">
                    @if (!string.IsNullOrEmpty(post.ThumbnailUrl))
                    {
                        <div class="home-post-thumb" style="background-image: url('@post.ThumbnailUrl')"></div>
                    }
                    else
                    {
                        <div class="home-post-thumb home-post-thumb-placeholder">
                            <i class="ti ti-file-text"></i>
                        </div>
                    }
                    <div class="home-post-body">
                        <div class="home-post-category">@post.BlogCategory?.Name</div>
                        <div class="home-post-title">@post.Title</div>
                        <div class="home-post-date">
                            <i class="ti ti-calendar" style="font-size:11px;"></i>
                            @post.CreatedDate.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
}