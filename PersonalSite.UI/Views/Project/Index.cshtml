@model List<EntityLayer.Concrete.Project>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Projeler";
}

<div style="background: var(--bg-card); border: 0.5px solid var(--border); border-radius: 10px; overflow: hidden;">
    <div style="padding: 14px 18px; border-bottom: 0.5px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
        <span style="font-size: 14px; font-weight: 500;">Projeler</span>
        <a href="/Project/Create" style="font-size: 12px; padding: 5px 12px; border-radius: 6px; background: var(--accent); color: var(--accent-text); text-decoration: none; display: flex; align-items: center; gap: 5px;">
            <i class="ti ti-plus"></i> Yeni Proje
        </a>
    </div>

    @if (!Model.Any())
    {
        <div style="padding: 40px; text-align: center; color: var(--text-muted); font-size: 13px;">
            Henüz proje yok.
        </div>
    }
    else
    {
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
            <thead>
                <tr style="border-bottom: 0.5px solid var(--border);">
                    <th style="padding: 10px 18px; text-align: left; color: var(--text-muted); font-weight: 500;">Başlık</th>
                    <th style="padding: 10px 18px; text-align: left; color: var(--text-muted); font-weight: 500;">Teknolojiler</th>
                    <th style="padding: 10px 18px; text-align: left; color: var(--text-muted); font-weight: 500;">GitHub</th>

                    <th style="padding: 10px 18px; text-align: left; color: var(--text-muted); font-weight: 500;">Durum</th>
                    <th style="padding: 10px 18px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model)
                {
                    <tr style="border-bottom: 0.5px solid var(--border);">
                        <td style="padding: 12px 18px;">@project.Title</td>
                        <td style="padding: 12px 18px; color: var(--text-muted);">@project.Technologies</td>
                        <td style="padding: 12px 18px;">
                            @if (!string.IsNullOrEmpty(project.GitHubUrl))
                            {
                                <a href="@project.GitHubUrl" target="_blank" style="color: var(--accent); font-size: 12px;">
                                    <i class="ti ti-brand-github"></i> GitHub
                                </a>
                            }
                        </td>
                        <td style="padding: 12px 18px;">
                            @if (project.IsActive)
                            {
                                <span style="font-size: 11px; padding: 2px 8px; border-radius: 99px; background: rgba(99,153,34,0.12); color: #639922;">Yayında</span>
                            }
                            else
                            {
                                <span style="font-size: 11px; padding: 2px 8px; border-radius: 99px; background: rgba(56,189,248,0.12); color: var(--accent);">Taslak</span>
                            }
                        </td>
                        

                        <td style="padding: 12px 18px; display: flex; gap: 6px; justify-content: flex-end;">
                            <a href="/Project/Edit/@project.Id" style="width: 28px; height: 28px; border-radius: 6px; border: 0.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); text-decoration: none;">
                                <i class="ti ti-edit"></i>
                            </a>
                            <a href="/Project/Delete/@project.Id" style="width: 28px; height: 28px; border-radius: 6px; border: 0.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); text-decoration: none;" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                <i class="ti ti-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>